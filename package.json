{
  "name": "visitor-system",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "start": "turbo start",
    "dev:api": "turbo dev --filter=@visitor-system/api",
    "dev:mobile": "turbo dev --filter=@visitor-system/mobile",
    "start:api": "turbo start --filter=@visitor-system/api"
  },
  "devDependencies": {
    "turbo": "^2.5.4"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.9.2"
}
